{
  "name": "@daw/ai-source-separation",
  "version": "1.0.0",
  "description": "AI-powered source separation for DAW - extract vocals, drums, bass from any audio",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
