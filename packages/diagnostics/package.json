{
  "name": "@daw/diagnostics",
  "version": "0.1.0",
  "description": "Capability detection, diagnostics, and telemetry for the In-Browser DAW",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./capabilities": {
      "import": "./dist/capabilities.js",
      "types": "./dist/capabilities.d.ts"
    },
    "./diagnostics": {
      "import": "./dist/diagnostics.js",
      "types": "./dist/diagnostics.d.ts"
    },
    "./telemetry": {
      "import": "./dist/telemetry.js",
      "types": "./dist/telemetry.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/**/*.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT"
}
