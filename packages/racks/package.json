{
  "name": "@daw/racks",
  "version": "1.0.0",
  "description": "Ableton-style Racks System for the In-Browser DAW",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/**/*.ts"
  },
  "keywords": [
    "daw",
    "audio",
    "racks",
    "ableton",
    "chains",
    "macros",
    "instrument-rack",
    "drum-rack",
    "effect-rack",
    "webaudio"
  ],
  "author": "DAW Team",
  "license": "MIT",
  "dependencies": {
    "@daw/plugin-api": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "vitest": "^1.0.0",
    "@types/node": "^20.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
