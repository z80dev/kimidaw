# Security Headers Configuration for In-Browser DAW
#
# This file documents the required HTTP response headers for the DAW
# to function correctly with advanced browser APIs.
#
# See spec section 21.1: Required response headers
#
# For production deployment, configure these headers in your:
# - CDN (Cloudflare, Fastly, etc.)
# - Reverse proxy (nginx, Apache, etc.)
# - Application server
# - Edge functions (Vercel, Netlify, Cloudflare Workers, etc.)

# =============================================================================
# CRITICAL: Cross-Origin Isolation Headers
# =============================================================================
#
# These headers are REQUIRED for:
# - SharedArrayBuffer (SAB) support
# - High-resolution performance.now()
# - AudioWorklet cross-origin worklet loading
#
# See: https://developer.mozilla.org/en-US/docs/Web/JavaScript/Reference/Global_Objects/SharedArrayBuffer#security_requirements

# Cross-Origin-Opener-Policy
# Ensures the document cannot share a browsing context with cross-origin documents
Cross-Origin-Opener-Policy: same-origin

# Cross-Origin-Embedder-Policy
# Requires all resources to explicitly allow being embedded
Cross-Origin-Embedder-Policy: require-corp

# Cross-Origin-Resource-Policy
# Indicates which origins can include this resource
# Set on the main document
Cross-Origin-Resource-Policy: same-origin

# =============================================================================
# CORS Headers
# =============================================================================
#
# Required for loading worklets, WASM, and audio assets from same-origin
# with proper cross-origin isolation compliance.

# Access-Control-Allow-Origin
# For production, use explicit origin instead of *
Access-Control-Allow-Origin: https://your-domain.com

# Access-Control-Allow-Methods
Access-Control-Allow-Methods: GET, HEAD, OPTIONS

# Access-Control-Allow-Headers
Access-Control-Allow-Headers: Content-Type, Range

# =============================================================================
# Content Security Policy
# =============================================================================
#
# Required to allow worklets, workers, WASM execution while maintaining security.
# Adjust based on your asset pipeline and plugin loading requirements.
#
# WARNING: This is a restrictive baseline. You may need to adjust 'unsafe-eval'
# if using certain WASM compilation patterns or eval-based scripting.

Content-Security-Policy: default-src 'self'; 
    script-src 'self' 'wasm-unsafe-eval' blob:; 
    worker-src 'self' blob:; 
    style-src 'self' 'unsafe-inline'; 
    img-src 'self' blob: data:; 
    media-src 'self' blob:; 
    connect-src 'self' wss: https:; 
    font-src 'self'; 
    object-src 'none'; 
    frame-ancestors 'none'; 
    base-uri 'self'; 
    form-action 'self';

# =============================================================================
# Permissions Policy
# =============================================================================
#
# Controls which browser features the page can use.
# The DAW requires several powerful APIs.
#
# See spec section 21.1

Permissions-Policy: 
    midi=(self), 
    midi-sysex=(self), 
    microphone=(self), 
    speaker-selection=(self), 
    display-capture=(self), 
    fullscreen=(self), 
    autoplay=(self);

# =============================================================================
# CORP on Assets
# =============================================================================
#
# All static assets (JS, CSS, WASM, audio, worklets) must include:
# Cross-Origin-Resource-Policy: cross-origin
#
# This allows them to be loaded in a cross-origin isolated context.
#
# Configure this in your static file server or CDN for:
# - *.js
# - *.wasm
# - *.worklet.js
# - *.worker.js
# - Audio samples (wav, mp3, etc.)

# =============================================================================
# Additional Security Headers
# =============================================================================

# Strict-Transport-Security (HSTS)
# Required for HTTPS deployment
Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

# X-Content-Type-Options
# Prevents MIME type sniffing
X-Content-Type-Options: nosniff

# X-Frame-Options
# Prevents clickjacking
X-Frame-Options: DENY

# Referrer-Policy
# Controls referrer information
Referrer-Policy: strict-origin-when-cross-origin

# X-DNS-Prefetch-Control
# Disable DNS prefetching for privacy
X-DNS-Prefetch-Control: off

# =============================================================================
# Example nginx Configuration
# =============================================================================
#
# server {
#     listen 443 ssl http2;
#     server_name daw.example.com;
#     
#     # SSL configuration...
#     
#     # Cross-origin isolation headers
#     add_header Cross-Origin-Opener-Policy "same-origin" always;
#     add_header Cross-Origin-Embedder-Policy "require-corp" always;
#     add_header Cross-Origin-Resource-Policy "same-origin" always;
#     
#     # Content Security Policy
#     add_header Content-Security-Policy "default-src 'self'; script-src 'self' 'wasm-unsafe-eval' blob:; worker-src 'self' blob:; style-src 'self' 'unsafe-inline'; img-src 'self' blob: data:; media-src 'self' blob:; connect-src 'self' wss: https:; font-src 'self'; object-src 'none'; frame-ancestors 'none'; base-uri 'self'; form-action 'self';" always;
#     
#     # Permissions Policy
#     add_header Permissions-Policy "midi=(self), midi-sysex=(self), microphone=(self), speaker-selection=(self), display-capture=(self), fullscreen=(self), autoplay=(self)" always;
#     
#     # Security headers
#     add_header Strict-Transport-Security "max-age=31536000; includeSubDomains; preload" always;
#     add_header X-Content-Type-Options "nosniff" always;
#     add_header X-Frame-Options "DENY" always;
#     add_header Referrer-Policy "strict-origin-when-cross-origin" always;
#     
#     location / {
#         root /var/www/daw;
#         try_files $uri $uri/ /index.html;
#     }
#     
#     # Static assets with CORP header
#     location ~* \.(js|wasm|css|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot|wav|mp3|ogg|flac)$ {
#         root /var/www/daw;
#         expires 1y;
#         add_header Cache-Control "public, immutable";
#         add_header Cross-Origin-Resource-Policy "cross-origin";
#     }
# }

